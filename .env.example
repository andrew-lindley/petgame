# ─────────────────────────────────────────────
#  Cat Pet Simulator — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Required: Your OpenAI API key for sprite generation
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: Public base URL used to build sprite image URLs.
# Defaults to http://localhost:3000 in development.
# Set this to your deployed domain in production, e.g.:
# PUBLIC_URL=https://mypetsimulator.com
PUBLIC_URL=

# Optional: Port the Express server listens on (default: 3000)
PORT=3000
